# barenode — Provider & Credential Configuration
#
# Copy this file to .env and edit to match your preferred provider.
# The .env file is gitignored — your keys stay local.

# --- Provider Selection ---
# Format: provider/model_name
# Examples:
#   ollama/qwen2.5:8b
#   openrouter/qwen-qwq-32b
#   lstudio/gemma-2-27b-it
#   fake/echo
BARENODE_MODEL=ollama/qwen2.5:8b

# --- GitHub (needed to push commits) ---
# Create a fine-grained personal access token at:
# GitHub Settings → Developer settings → Personal access tokens → Fine-grained tokens
# Grant: Contents (read+write), Metadata (read-only) for this repo only
GITHUB_TOKEN=

# --- OpenRouter (only needed if using openrouter/*) ---
OPENROUTER_API_KEY=

# --- LM Studio (only needed if using lstudio/*) ---
# LM Studio runs at http://localhost:1234/v1 by default
LM_STUDIO_BASE_URL=http://localhost:1234/v1